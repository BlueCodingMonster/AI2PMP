// ============================================================================
// AI2PmP - 研发项目管理系统 Prisma Schema
// Prisma v7 格式：datasource URL 已移至 prisma.config.ts
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// 枚举定义
// ============================================================================

/// 项目状态
enum ProjectStatus {
  CONTRACT_SIGNED // 合同签订
  IMPLEMENTING // 实施中
  ACCEPTANCE // 验收中
  ARCHIVED // 完成归档
}

/// 项目成员角色
enum ProjectRole {
  OWNER // 拥有者
  ADMIN // 管理员
  DEVELOPER // 开发者
  TESTER // 测试人员
  VIEWER // 观察者
}

/// 需求状态
enum RequirementStatus {
  PENDING_REVIEW // 待评审
  UNDER_REVIEW // 评审中
  REVIEWED // 已评审
  REJECTED // 已驳回
  SCHEDULED // 已排期
  COMPLETED // 已完成
}

/// 需求来源
enum RequirementSource {
  PRODUCT_PLANNING // 产品规划
  CUSTOMER_FEEDBACK // 客户反馈
  INTERNAL_REQUEST // 公司内部需求
  MARKET_REQUEST // 市场需求
}

/// 优先级（通用）
enum Priority {
  URGENT // 紧急
  HIGH // 高
  MEDIUM // 中
  LOW // 低
}

enum PlanPublicationStatus {
  DRAFT
  PUBLISHED
}

enum QuarterlyGoalDomain {
  PRODUCT_ITERATION
  PRODUCT_DELIVERY
  PRODUCT_RESEARCH
  MARKET_SUPPORT
  OPERATIONS_STABILITY
  TECHNICAL_INNOVATION
  AI_ENABLEMENT
}

enum PlanTrackingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DELAY_RISK
  DELAYED
  PAUSED
}

enum PlanRiskLevel {
  HIGH
  MEDIUM
  LOW
}

enum QuarterlyRiskStatus {
  NOT_TRIGGERED
  TRIGGERED
  HANDLING
  CLOSED
}

enum ResourceRequestType {
  PEOPLE
  TECHNOLOGY
  BUDGET
  MANAGEMENT_COORDINATION
}



/// 产品线成员岗位角色
enum ProductLineRole {
  LEADER // 组长
  PM // 产品经理
  FRONTEND // 前端开发
  BACKEND // 后端开发
  TESTER // 测试工程师
}

/// 人员借调状态
enum SecondmentStatus {
  ACTIVE // 借调中
  COMPLETED // 已结束
}

/// 产品版本状态
enum ProductVersionStatus {
  PLANNING
  DESIGNING
  DEVELOPING
  TESTING
  RELEASED
  DELAYED
  CANCELLED
}

enum OperationVersionType {
  PRODUCT
  PROJECT
}

enum OperationType {
  DATA_REPAIR
  ENVIRONMENT_CONFIGURATION
  CONSULTATION
  CODE_BUG
  OTHER
}

enum OperationStatus {
  PENDING
  PROCESSING
  PENDING_CONFIRMATION
  COMPLETED
}

enum CustomerConfirmationStatus {
  PENDING
  CONFIRMED
}

enum ManagedTaskCategory {
  DEVELOPMENT
  OTHER
}

enum ManagedTaskStatus {
  UNSCHEDULED
  TODO
  IN_PROGRESS
  PAUSED
  DONE
  CANCELLED
}

enum ManagedTaskVersionType {
  PRODUCT
  PROJECT
}

enum ManagedTaskMonthlyItemType {
  PRODUCT_DELIVERY
  PROJECT_DELIVERY
  MARKET_ACTION
  COST_OPTIMIZATION
  AI_PRODUCT_ENABLEMENT
  AI_EFFICIENCY
  RISK
  RESOURCE_REQUEST
}

enum ManagedTaskSdlcNode {
  REQUIREMENT_ANALYSIS
  SOLUTION_DESIGN
  DEVELOPMENT
  INTEGRATION
  TESTING
  RELEASE
  ACCEPTANCE
  OPERATION_OBSERVATION
  OTHER
}

enum WorkCalendarStatus {
  DRAFT
  PUBLISHED
}

enum WorkCalendarDayType {
  REGULAR_WORKDAY
  REGULAR_WEEKEND
  LEGAL_HOLIDAY
  ADJUSTED_WORKDAY
  SPECIAL_REST_DAY
  SPECIAL_WORKDAY
}

// ============================================================================
// 数据模型
// ============================================================================

/// 用户模型 - 系统核心用户表
model User {
  id         String   @id @default(cuid())
  username   String   @unique // 登录名
  email      String?  @unique // 可选联系邮箱，不再作为登录账号
  name       String
  password   String // bcrypt 加密存储
  avatar     String? // 头像 URL
  phone      String? // 手机号
  department String? // 部门
  level      String? // 人员层级
  position   String? // 专业岗位
  isAdmin    Boolean  @default(false) // 是否管理员
  isActive   Boolean  @default(true) // 是否启用
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // 关联关系
  createdProjects         Project[]              @relation("ProjectCreator")
  managedProjects         Project[]              @relation("ProjectManager")
  projectMemberships      ProjectMember[]
  createdRequirements     Requirement[]          @relation("RequirementCreator")
  createdQuarterlyPlans   QuarterlyPlan[]        @relation("QuarterlyPlanCreator")
  updatedQuarterlyPlans   QuarterlyPlan[]        @relation("QuarterlyPlanUpdater")
  createdMonthlyPlans     MonthlyPlan[]          @relation("MonthlyPlanCreator")
  updatedMonthlyPlans     MonthlyPlan[]          @relation("MonthlyPlanUpdater")

  createdOperationRecords OperationRecord[]      @relation("OperationRecordCreator")
  handledOperationRecords OperationRecord[]      @relation("OperationRecordHandlers")
  createdManagedTasks     ManagedTask[]          @relation("ManagedTaskCreator")
  executedManagedTasks    ManagedTask[]          @relation("ManagedTaskExecutor")
  managedTaskStatusLogs   ManagedTaskStatusLog[]

  // 产品线与借调关联
  productLineMemberships ProductLineMember[]
  secondments            MemberSecondment[]
  auditLogs              AuditLog[]

  @@index([username])
  @@index([email])
  @@index([isActive])
  @@map("users")
}

/// 项目模型
model Project {
  id                String        @id @default(cuid())
  name              String
  key               String        @unique // 项目唯一标识，如 "AI2P"
  customerName      String        @default("")
  customerContact   String?
  customerPhone     String?
  projectManagerId  String?
  marketManager     String?
  salesManager      String?
  contractNumber    String?
  contractAmount    Decimal?      @db.Decimal(18, 2)
  contractSignedAt  DateTime?
  warrantyMonths    Int?
  warrantyExpiresAt DateTime?
  status            ProjectStatus @default(CONTRACT_SIGNED)
  acceptanceDate    DateTime?
  description       String?       @db.Text
  createdById       String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // 关联关系
  createdBy      User             @relation("ProjectCreator", fields: [createdById], references: [id])
  projectManager User?            @relation("ProjectManager", fields: [projectManagerId], references: [id], onDelete: SetNull)
  members        ProjectMember[]
  versions       ProjectVersion[]

  // 关联产品线小组
  productLineTeamId String?
  productLineTeam   ProductLineTeam? @relation(fields: [productLineTeamId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdById])
  @@index([projectManagerId])
  @@index([key])
  @@index([productLineTeamId])
  @@map("projects")
}

/// 项目交付版本记录
model ProjectVersion {
  id        String   @id @default(cuid())
  projectId String
  version   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project               Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ownedOperationRecords OperationRecord[] @relation("OperationRecordProjectVersion")
  fixedOperationRecords OperationRecord[] @relation("OperationRecordFixedProjectVersion")
  managedTasks          ManagedTask[]     @relation("ManagedTaskProjectVersion")

  @@unique([projectId, version])
  @@index([projectId])
  @@map("project_versions")
}

/// 项目成员模型 - 管理用户与项目的多对多关系及角色
model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(DEVELOPER)
  joinedAt  DateTime    @default(now())

  // 关联关系
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId]) // 同一用户在同一项目中只能有一个角色
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

/// 需求模型 - 产品需求管理
model Requirement {
  id                String            @id @default(cuid())
  sequenceNo        Int               @unique @default(autoincrement())
  title             String
  summary           String?           @db.Text
  status            RequirementStatus @default(PENDING_REVIEW)
  source            RequirementSource
  priority          Priority          @default(MEDIUM)
  productLineTeamId String?
  proposer          String?
  proposedAt        DateTime?
  reviewedAt        DateTime?
  createdById       String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // 关联关系
  createdBy       User             @relation("RequirementCreator", fields: [createdById], references: [id])
  productLineTeam ProductLineTeam? @relation(fields: [productLineTeamId], references: [id], onDelete: SetNull)


  @@index([status])
  @@index([priority])
  @@index([createdById])
  @@index([source])
  @@index([productLineTeamId])
  @@map("requirements")
}

model QuarterlyPlan {
  id                String                @id @default(cuid())
  productLineTeamId String
  year              Int
  quarter           Int
  status            PlanPublicationStatus @default(DRAFT)
  createdById       String
  updatedById       String
  publishedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  goals           QuarterlyGoal[]
  risks           QuarterlyRisk[]
  productLineTeam ProductLineTeam @relation(fields: [productLineTeamId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("QuarterlyPlanCreator", fields: [createdById], references: [id])
  updatedBy       User            @relation("QuarterlyPlanUpdater", fields: [updatedById], references: [id])

  @@unique([productLineTeamId, year, quarter])
  @@index([status])
  @@index([year, quarter])
  @@map("quarterly_plans")
}

model QuarterlyGoal {
  id                String               @id @default(cuid())
  quarterlyPlanId   String
  domain            QuarterlyGoalDomain?
  quarterlyGoal     String?              @db.Text
  successCriteria   String?              @db.Text
  month1Goal        String?              @db.Text
  month1Status      PlanTrackingStatus?
  month2Goal        String?              @db.Text
  month2Status      PlanTrackingStatus?
  month3Goal        String?              @db.Text
  month3Status      PlanTrackingStatus?
  currentCompletion String?              @db.Text
  achievementRate   Int                  @default(0)
  quarterlyStatus   PlanTrackingStatus?
  keyDependencies   String?              @db.Text
  notes             String?              @db.Text
  sortOrder         Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  quarterlyPlan QuarterlyPlan @relation(fields: [quarterlyPlanId], references: [id], onDelete: Cascade)

  @@index([quarterlyPlanId, sortOrder])
  @@map("quarterly_goals")
}

model QuarterlyRisk {
  id                String               @id @default(cuid())
  quarterlyPlanId   String
  riskDescription   String?              @db.Text
  affectedMilestone String?
  probability       PlanRiskLevel?
  impact            PlanRiskLevel?
  overallLevel      PlanRiskLevel?
  triggerCondition  String?              @db.Text
  responseStrategy  String?              @db.Text
  warningPoint      String?
  status            QuarterlyRiskStatus?
  sortOrder         Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  quarterlyPlan QuarterlyPlan @relation(fields: [quarterlyPlanId], references: [id], onDelete: Cascade)

  @@index([quarterlyPlanId, sortOrder])
  @@map("quarterly_risks")
}

model MonthlyPlan {
  id                String                @id @default(cuid())
  productLineTeamId String
  year              Int
  month             Int
  status            PlanPublicationStatus @default(DRAFT)
  createdById       String
  updatedById       String
  publishedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  productDeliveries    MonthlyProductDelivery[]
  projectDeliveries    MonthlyProjectDelivery[]
  marketActions        MonthlyMarketAction[]
  costOptimizations    MonthlyCostOptimization[]
  aiProductEnablements MonthlyAiProductEnablement[]
  aiEfficiencies       MonthlyAiEfficiency[]
  risks                MonthlyRisk[]
  resourceRequests     MonthlyResourceRequest[]
  productLineTeam      ProductLineTeam              @relation(fields: [productLineTeamId], references: [id], onDelete: Cascade)
  createdBy            User                         @relation("MonthlyPlanCreator", fields: [createdById], references: [id])
  updatedBy            User                         @relation("MonthlyPlanUpdater", fields: [updatedById], references: [id])
  managedTasks         ManagedTask[]

  @@unique([productLineTeamId, year, month])
  @@index([status])
  @@index([year, month])
  @@map("monthly_plans")
}

model MonthlyProductDelivery {
  id                    String      @id @default(cuid())
  monthlyPlanId         String
  moduleVersion         String?
  deliveryContent       String?     @db.Text
  plannedCompletionDate DateTime?
  sortOrder             Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  monthlyPlan           MonthlyPlan @relation(fields: [monthlyPlanId], references: [id], onDelete: Cascade)

  @@index([monthlyPlanId, sortOrder])
  @@map("monthly_product_deliveries")
}

model MonthlyProjectDelivery {
  id                    String      @id @default(cuid())
  monthlyPlanId         String
  projectName           String?
  deliveryContent       String?     @db.Text
  plannedCompletionDate DateTime?
  customerName          String?
  sortOrder             Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  monthlyPlan           MonthlyPlan @relation(fields: [monthlyPlanId], references: [id], onDelete: Cascade)

  @@index([monthlyPlanId, sortOrder])
  @@map("monthly_project_deliveries")
}

model MonthlyMarketAction {
  id                    String      @id @default(cuid())
  monthlyPlanId         String
  productOrProject      String?
  marketAction          String?     @db.Text
  outputResult          String?     @db.Text
  plannedCompletionDate DateTime?
  sortOrder             Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  monthlyPlan           MonthlyPlan @relation(fields: [monthlyPlanId], references: [id], onDelete: Cascade)

  @@index([monthlyPlanId, sortOrder])
  @@map("monthly_market_actions")
}

model MonthlyCostOptimization {
  id                  String      @id @default(cuid())
  monthlyPlanId       String
  optimizationItem    String?
  currentProblem      String?     @db.Text
  optimizationMeasure String?     @db.Text
  sortOrder           Int         @default(0)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  monthlyPlan         MonthlyPlan @relation(fields: [monthlyPlanId], references: [id], onDelete: Cascade)

  @@index([monthlyPlanId, sortOrder])
  @@map("monthly_cost_optimizations")
}

model MonthlyAiProductEnablement {
  id                    String      @id @default(cuid())
  monthlyPlanId         String
  item                  String?
  outputResult          String?     @db.Text
  plannedCompletionDate DateTime?
  sortOrder             Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  monthlyPlan           MonthlyPlan @relation(fields: [monthlyPlanId], references: [id], onDelete: Cascade)

  @@index([monthlyPlanId, sortOrder])
  @@map("monthly_ai_product_enablements")
}

model MonthlyAiEfficiency {
  id                    String      @id @default(cuid())
  monthlyPlanId         String
  item                  String?
  outputResult          String?     @db.Text
  plannedCompletionDate DateTime?
  sortOrder             Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  monthlyPlan           MonthlyPlan @relation(fields: [monthlyPlanId], references: [id], onDelete: Cascade)

  @@index([monthlyPlanId, sortOrder])
  @@map("monthly_ai_efficiencies")
}

model MonthlyRisk {
  id              String         @id @default(cuid())
  monthlyPlanId   String
  riskItem        String?
  riskLevel       PlanRiskLevel?
  impactScope     String?        @db.Text
  responseMeasure String?        @db.Text
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  monthlyPlan     MonthlyPlan    @relation(fields: [monthlyPlanId], references: [id], onDelete: Cascade)

  @@index([monthlyPlanId, sortOrder])
  @@map("monthly_risks")
}

model MonthlyResourceRequest {
  id                String               @id @default(cuid())
  monthlyPlanId     String
  requestType       ResourceRequestType?
  content           String?              @db.Text
  urgency           PlanRiskLevel?
  supportDepartment String?
  sortOrder         Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  monthlyPlan       MonthlyPlan          @relation(fields: [monthlyPlanId], references: [id], onDelete: Cascade)

  @@index([monthlyPlanId, sortOrder])
  @@map("monthly_resource_requests")
}

/// 产品线小组模型
model ProductLineTeam {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联项目
  projects Project[]

  // 关联产品线（产品目录，可多小组协作）
  products Product[] @relation("ProductLineTeamProducts")

  // 关联需求
  requirements   Requirement[]
  quarterlyPlans QuarterlyPlan[]
  monthlyPlans   MonthlyPlan[]
  managedTasks   ManagedTask[]
  workCalendars  WorkCalendarYear[]

  // 固定成员
  members ProductLineMember[]

  // 借入/借出的借调记录
  secondmentsFrom MemberSecondment[] @relation("SecondedFrom")
  secondmentsTo   MemberSecondment[] @relation("SecondedTo")

  @@map("product_line_teams")
}

/// 产品/项目模型
model Product {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions         ProductVersion[]
  productLineTeams ProductLineTeam[] @relation("ProductLineTeamProducts")

  @@map("products")
}

/// 产品版本模型
model ProductVersion {
  id          String               @id @default(cuid())
  title       String
  version     String
  description String?              @db.Text
  status      ProductVersionStatus @default(PLANNING)
  productId   String
  startDate   DateTime?
  releaseDate DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  product               Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  ownedOperationRecords OperationRecord[] @relation("OperationRecordProductVersion")
  fixedOperationRecords OperationRecord[] @relation("OperationRecordFixedProductVersion")
  managedTasks          ManagedTask[]     @relation("ManagedTaskProductVersion")

  @@unique([productId, version])
  @@index([productId])
  @@index([status])
  @@map("product_versions")
}

model OperationRecord {
  id                         String                     @id @default(cuid())
  sequenceNo                 Int                        @unique @default(autoincrement())
  ownershipVersionType       OperationVersionType
  ownershipProductVersionId  String?
  ownershipProjectVersionId  String?
  type                       OperationType
  eventDescription           String                     @db.Text
  occurredAt                 DateTime
  reporter                   String
  status                     OperationStatus            @default(PENDING)
  operationContent           String                     @db.Text
  processingStartedAt        DateTime?
  processingCompletedAt      DateTime?
  customerConfirmationStatus CustomerConfirmationStatus @default(PENDING)
  fixVersionType             OperationVersionType?
  fixProductVersionId        String?
  fixProjectVersionId        String?
  followUpActions            String?                    @db.Text
  notes                      String?                    @db.Text
  createdById                String
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt

  ownershipProductVersion ProductVersion? @relation("OperationRecordProductVersion", fields: [ownershipProductVersionId], references: [id], onDelete: Restrict)
  ownershipProjectVersion ProjectVersion? @relation("OperationRecordProjectVersion", fields: [ownershipProjectVersionId], references: [id], onDelete: Restrict)
  fixProductVersion       ProductVersion? @relation("OperationRecordFixedProductVersion", fields: [fixProductVersionId], references: [id], onDelete: SetNull)
  fixProjectVersion       ProjectVersion? @relation("OperationRecordFixedProjectVersion", fields: [fixProjectVersionId], references: [id], onDelete: SetNull)
  createdBy               User            @relation("OperationRecordCreator", fields: [createdById], references: [id], onDelete: Restrict)
  handlers                User[]          @relation("OperationRecordHandlers")

  @@index([ownershipVersionType])
  @@index([ownershipProductVersionId])
  @@index([ownershipProjectVersionId])
  @@index([type])
  @@index([status])
  @@index([occurredAt])
  @@map("operation_records")
}

model ManagedTask {
  id                String                      @id @default(cuid())
  sequenceNo        Int                         @unique @default(autoincrement())
  title             String
  description       String?                     @db.Text
  level             Int
  parentId          String?
  category          ManagedTaskCategory?
  sdlcNode          ManagedTaskSdlcNode?
  status            ManagedTaskStatus           @default(UNSCHEDULED)
  planStartDate     DateTime?
  planEndDate       DateTime?
  plannedWorkdays   Float                       @default(0)
  progressPercent   Int                         @default(0)
  actualStartAt     DateTime?
  actualFinishAt    DateTime?
  actualWorkdays    Float                       @default(0)
  executorId        String?
  productLineTeamId String
  monthlyPlanId     String?
  monthlyItemType   ManagedTaskMonthlyItemType?
  monthlyItemId     String?
  versionType       ManagedTaskVersionType?
  productVersionId  String?
  projectVersionId  String?
  notes             String?                     @db.Text
  createdById       String
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  parent          ManagedTask?           @relation("ManagedTaskHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        ManagedTask[]          @relation("ManagedTaskHierarchy")
  createdBy       User                   @relation("ManagedTaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  executor        User?                  @relation("ManagedTaskExecutor", fields: [executorId], references: [id], onDelete: SetNull)
  productLineTeam ProductLineTeam        @relation(fields: [productLineTeamId], references: [id], onDelete: Restrict)
  monthlyPlan     MonthlyPlan?           @relation(fields: [monthlyPlanId], references: [id], onDelete: SetNull)
  productVersion  ProductVersion?        @relation("ManagedTaskProductVersion", fields: [productVersionId], references: [id], onDelete: SetNull)
  projectVersion  ProjectVersion?        @relation("ManagedTaskProjectVersion", fields: [projectVersionId], references: [id], onDelete: SetNull)
  statusLogs      ManagedTaskStatusLog[]

  @@index([parentId])
  @@index([level])
  @@index([category])
  @@index([status])
  @@index([executorId])
  @@index([productLineTeamId])
  @@index([monthlyPlanId])
  @@index([productVersionId])
  @@index([projectVersionId])
  @@index([planStartDate, planEndDate])
  @@map("managed_tasks")
}


model ManagedTaskStatusLog {
  id          String             @id @default(cuid())
  taskId      String
  fromStatus  ManagedTaskStatus?
  toStatus    ManagedTaskStatus
  changedById String
  changedAt   DateTime           @default(now())
  note        String?            @db.Text

  task      ManagedTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy User        @relation(fields: [changedById], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([changedById])
  @@index([changedAt])
  @@map("managed_task_status_logs")
}

model WorkCalendarYear {
  id                String             @id @default(cuid())
  productLineTeamId String?
  year              Int
  status            WorkCalendarStatus @default(DRAFT)
  standardHours     Float              @default(8)
  publishedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  productLineTeam ProductLineTeam?  @relation(fields: [productLineTeamId], references: [id], onDelete: Cascade)
  days            WorkCalendarDay[]

  @@unique([productLineTeamId, year])
  @@index([year])
  @@index([status])
  @@map("work_calendar_years")
}

model WorkCalendarDay {
  id             String              @id @default(cuid())
  calendarYearId String
  date           DateTime
  type           WorkCalendarDayType
  standardHours  Float?
  label          String?
  notes          String?             @db.Text

  calendarYear WorkCalendarYear @relation(fields: [calendarYearId], references: [id], onDelete: Cascade)

  @@unique([calendarYearId, date])
  @@index([date])
  @@index([type])
  @@map("work_calendar_days")
}

/// 产品线小组固定成员模型
model ProductLineMember {
  id       String          @id @default(cuid())
  teamId   String
  userId   String
  role     ProductLineRole
  joinedAt DateTime        @default(now())

  // 关联关系
  team ProductLineTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId]) // 每个成员在小组里是唯一的
  @@index([teamId])
  @@index([userId])
  @@map("product_line_members")
}

/// 人员临时借调记录模型
model MemberSecondment {
  id         String           @id @default(cuid())
  userId     String // 借调的人员 ID
  fromTeamId String? // 借出的原小组 ID (可选)
  toTeamId   String // 借入的目标小组 ID
  role       ProductLineRole // 借调期间在目标小组担任的角色
  startDate  DateTime // 借调开始时间
  endDate    DateTime? // 借调结束时间
  status     SecondmentStatus @default(ACTIVE)
  createdAt  DateTime // 登记时间
  updatedAt  DateTime         @updatedAt

  // 关联关系
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromTeam ProductLineTeam? @relation("SecondedFrom", fields: [fromTeamId], references: [id], onDelete: SetNull)
  toTeam   ProductLineTeam  @relation("SecondedTo", fields: [toTeamId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fromTeamId])
  @@index([toTeamId])
  @@index([status])
  @@map("member_secondments")
}

/// 系统审计日志模型 - 记录用户操作
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  // 操作用户 ID (可选，支持物理删除/游客)
  username  String   // 操作账号 (记录当时的值)
  name      String   // 用户姓名 (记录当时的值)
  action    String   // 操作类型 (如: "CREATE", "UPDATE", "DELETE", "LOGIN")
  module    String   // 业务模块 (如: "PROJECT", "WBS", "REQUIREMENT", "USER")
  details   String   @db.Text // 操作详情
  ip        String?  // 访问 IP 地址
  createdAt DateTime @default(now())

  // 关系定义
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

