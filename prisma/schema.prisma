// ============================================================================
// AI2PmP - 研发项目管理系统 Prisma Schema
// Prisma v7 格式：datasource URL 已移至 prisma.config.ts
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// 枚举定义
// ============================================================================

/// 项目状态
enum ProjectStatus {
  PLANNING   // 规划中
  ACTIVE     // 进行中
  ON_HOLD    // 暂停
  COMPLETED  // 已完成
  ARCHIVED   // 已归档
}

/// 项目成员角色
enum ProjectRole {
  OWNER     // 拥有者
  ADMIN     // 管理员
  DEVELOPER // 开发者
  TESTER    // 测试人员
  VIEWER    // 观察者
}

/// 需求状态
enum RequirementStatus {
  DRAFT        // 草稿
  UNDER_REVIEW // 评审中
  APPROVED     // 已批准
  PLANNED      // 已排期
  IN_PROGRESS  // 进行中
  COMPLETED    // 已完成
  REJECTED     // 已拒绝
  DEFERRED     // 已延期
}

/// 需求类型
enum RequirementType {
  FUNCTIONAL       // 功能需求
  NON_FUNCTIONAL   // 非功能需求
  ENHANCEMENT      // 功能增强
  OPTIMIZATION     // 性能优化
  TECH_DEBT        // 技术债务
}

/// 需求来源
enum RequirementSource {
  PRODUCT_PLANNING     // 产品规划
  CUSTOMER_FEEDBACK    // 客户反馈
  INTERNAL_SUGGESTION  // 内部建议
  MARKET_ANALYSIS      // 市场分析
  TECH_DEBT            // 技术债务
}

/// 优先级（通用）
enum Priority {
  URGENT // 紧急
  HIGH   // 高
  MEDIUM // 中
  LOW    // 低
}

/// 计划类型
enum PlanType {
  ANNUAL    // 年度计划
  HALF_YEAR // 半年度计划
  QUARTERLY // 季度计划
  MONTHLY   // 月度计划
}

/// 计划状态
enum PlanStatus {
  DRAFT       // 草稿
  PUBLISHED   // 已发布
  IN_PROGRESS // 进行中
  COMPLETED   // 已完成
  CANCELLED   // 已取消
}

/// 计划条目状态
enum PlanItemStatus {
  TODO        // 待办
  IN_PROGRESS // 进行中
  DONE        // 已完成
  CANCELLED   // 已取消
}

/// 工作项类型
enum WorkItemType {
  REQUIREMENT      // 需求
  VERSION_GOAL     // 版本目标
  PROJECT_MATTER   // 项目事项
  OPERATIONS       // 运维支撑
  MARKET_SUPPORT   // 市场支撑
  RESEARCH         // 技术调研
  DEFECT_FIX       // 缺陷或紧急修复
  TEMPORARY        // 其他临时工作
}

/// 计划外工作后续处理方式
enum PlanningTreatment {
  NOT_INCLUDED       // 不纳入计划，仅记录
  ADD_TO_CURRENT     // 补入当前月度计划
  MOVE_TO_NEXT       // 转入下个月度计划
  LINK_EXISTING_ITEM // 关联到已有工作项
}


/// 任务状态
enum TaskStatus {
  TODO        // 待办
  IN_PROGRESS // 进行中
  IN_REVIEW   // 评审中
  DONE        // 已完成
  CANCELLED   // 已取消
}

/// 任务类型
enum TaskType {
  FEATURE     // 新功能
  IMPROVEMENT // 改进
  TASK        // 普通任务
  SUBTASK     // 子任务
}

/// 缺陷状态
enum BugStatus {
  OPEN        // 新建
  CONFIRMED   // 已确认
  IN_PROGRESS // 修复中
  FIXED       // 已修复
  CLOSED      // 已关闭
  WONT_FIX    // 不修复
}

/// 缺陷严重程度
enum BugSeverity {
  BLOCKER  // 阻塞
  CRITICAL // 严重
  MAJOR    // 主要
  MINOR    // 次要
  TRIVIAL  // 轻微
}

/// 通知类型
enum NotificationType {
  TASK_ASSIGNED        // 任务分配
  TASK_UPDATED         // 任务更新
  BUG_ASSIGNED         // 缺陷分配
  BUG_UPDATED          // 缺陷更新
  MENTION              // 被提及
  REQUIREMENT_UPDATED  // 需求更新
  PLAN_PUBLISHED       // 计划发布
  SYSTEM               // 系统通知
}

/// 产品线成员岗位角色
enum ProductLineRole {
  LEADER    // 组长
  PM        // 产品经理
  FRONTEND  // 前端开发
  BACKEND   // 后端开发
  TESTER    // 测试工程师
}

/// 人员借调状态
enum SecondmentStatus {
  ACTIVE    // 借调中
  COMPLETED // 已结束
}

/// 产品版本状态
enum ProductVersionStatus {
  PLANNING
  DESIGNING
  DEVELOPING
  TESTING
  RELEASED
  DELAYED
  CANCELLED
}

// ============================================================================
// 数据模型
// ============================================================================

/// 用户模型 - 系统核心用户表
model User {
  id         String   @id @default(cuid())
  username   String   @unique // 登录名
  email      String?  @unique // 可选联系邮箱，不再作为登录账号
  name       String
  password   String   // bcrypt 加密存储
  avatar     String?  // 头像 URL
  phone      String?  // 手机号
  department String?  // 部门
  isAdmin    Boolean  @default(false) // 是否管理员
  isActive   Boolean  @default(true)  // 是否启用
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // 关联关系
  createdProjects      Project[]       @relation("ProjectCreator")
  projectMemberships   ProjectMember[]
  assignedRequirements Requirement[]   @relation("RequirementAssignee")
  createdRequirements  Requirement[]   @relation("RequirementCreator")
  createdPlans         Plan[]
  assignedPlanItems    PlanItem[]
  assignedTasks        Task[]          @relation("TaskAssignee")
  createdTasks         Task[]          @relation("TaskCreator")
  assignedBugs         Bug[]           @relation("BugAssignee")
  createdBugs          Bug[]           @relation("BugCreator")
  timeLogs             TimeLog[]
  notifications        Notification[]
  comments             Comment[]
  
  // 产品线与借调关联
  productLineMemberships ProductLineMember[]
  secondments            MemberSecondment[]

  @@index([username])
  @@index([email])
  @@index([isActive])
  @@map("users")
}

/// 项目模型
model Project {
  id          String        @id @default(cuid())
  name        String
  key         String        @unique // 项目唯一标识，如 "AI2P"
  description String?       @db.Text
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // 关联关系
  createdBy    User            @relation("ProjectCreator", fields: [createdById], references: [id])
  members      ProjectMember[]
  requirements Requirement[]
  planItems    PlanItem[]
  tasks        Task[]
  bugs         Bug[]
  
  // 关联产品线小组
  productLineTeamId String?
  productLineTeam   ProductLineTeam? @relation(fields: [productLineTeamId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdById])
  @@index([key])
  @@index([productLineTeamId])
  @@map("projects")
}

/// 项目成员模型 - 管理用户与项目的多对多关系及角色
model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(DEVELOPER)
  joinedAt  DateTime    @default(now())

  // 关联关系
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId]) // 同一用户在同一项目中只能有一个角色
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

/// 需求模型 - 产品需求管理
model Requirement {
  id                 String            @id @default(cuid())
  title              String
  description        String?           @db.Text
  status             RequirementStatus @default(DRAFT)
  type               RequirementType
  source             RequirementSource
  priority           Priority          @default(MEDIUM)
  businessValue      Int?              // 业务价值评分 (1-10)
  complexity         Int?              // 复杂度评分 (1-10)
  estimatedDays      Float?            // 预估工期（天）
  projectId          String?           // 可选：关联项目
  assigneeId         String?           // 可选：负责人
  createdById        String
  acceptanceCriteria String?           @db.Text // 验收标准
  sortOrder          Int               @default(0) // 排序权重
  
  // 新增：产品线关联、提出方、提出时间
  productLineTeamId  String?
  proposer           String?           // 需求提出方 (如: 销售部、运营部)
  proposedAt         DateTime?         // 需求提出物理时间
  
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  // 关联关系
  project           Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee          User?             @relation("RequirementAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy         User              @relation("RequirementCreator", fields: [createdById], references: [id])
  productLineTeam   ProductLineTeam?  @relation(fields: [productLineTeamId], references: [id], onDelete: SetNull)
  planItems         PlanItem[]
  tasks             Task[]
  comments          Comment[]

  @@index([status])
  @@index([priority])
  @@index([projectId])
  @@index([assigneeId])
  @@index([createdById])
  @@index([type])
  @@index([source])
  @@index([productLineTeamId])
  @@map("requirements")
}

/// 计划模型 - 年度/季度/月度计划
model Plan {
  id           String     @id @default(cuid())
  title        String
  description  String?    @db.Text
  type         PlanType
  status       PlanStatus @default(DRAFT)
  year         Int        // 所属年份
  quarter      Int?       // 所属季度 (1-4)，仅季度计划和月度计划使用
  month        Int?       // 所属月份 (1-12)，仅月度计划使用
  halfYear     Int?       // 所属半年度 (1-2)，仅半年度计划使用
  startDate    DateTime
  endDate      DateTime
  parentPlanId String?    // 父计划 ID，用于计划层级关系
  goals        String?    @db.Text // 计划目标描述
  productLineTeamId String
  createdById  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // 关联关系（自关联：父子计划）
  parentPlan Plan?  @relation("PlanHierarchy", fields: [parentPlanId], references: [id], onDelete: SetNull)
  childPlans Plan[] @relation("PlanHierarchy")
  productLineTeam ProductLineTeam @relation(fields: [productLineTeamId], references: [id])
  createdBy  User   @relation(fields: [createdById], references: [id])
  items      PlanItem[]

  @@index([status])
  @@index([type])
  @@index([year])
  @@index([parentPlanId])
  @@index([productLineTeamId])
  @@index([createdById])
  @@map("plans")
}

/// 计划条目模型 - 计划中的具体工作项
model PlanItem {
  id            String         @id @default(cuid())
  planId        String?
  productLineTeamId String?
  title         String
  description   String?        @db.Text
  type          WorkItemType   @default(REQUIREMENT)
  isPlanned     Boolean        @default(true)
  planningTreatment PlanningTreatment?
  relatedPlanItemId String?
  requirementId String?        // 可选：关联需求
  projectId     String?        // 可选：关联项目
  productVersionId String?     // 可选：关联产品版本
  taskId        String?        // 可选：关联任务
  assigneeId    String?        // 可选：负责人
  status        PlanItemStatus @default(TODO)
  progress      Int            @default(0) // 完成进度 (0-100)
  sortOrder     Int            @default(0) // 排序权重
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // 关联关系
  plan        Plan?        @relation(fields: [planId], references: [id], onDelete: Cascade)
  productLineTeam ProductLineTeam? @relation(fields: [productLineTeamId], references: [id], onDelete: SetNull)
  relatedPlanItem PlanItem? @relation("PlanItemRelation", fields: [relatedPlanItemId], references: [id], onDelete: SetNull)
  relatedChildren PlanItem[] @relation("PlanItemRelation")
  requirement Requirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  productVersion ProductVersion? @relation(fields: [productVersionId], references: [id], onDelete: SetNull)
  task        Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  assignee    User?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([planId])
  @@index([productLineTeamId])
  @@index([type])
  @@index([isPlanned])
  @@index([planningTreatment])
  @@index([relatedPlanItemId])
  @@index([status])
  @@index([assigneeId])
  @@index([requirementId])
  @@index([projectId])
  @@index([productVersionId])
  @@index([taskId])
  @@map("plan_items")
}

/// 任务模型 - 项目中的具体任务
model Task {
  id             String     @id @default(cuid())
  title          String
  description    String?    @db.Text
  status         TaskStatus @default(TODO)
  priority       Priority   @default(MEDIUM)
  type           TaskType   @default(TASK)
  projectId      String
  requirementId  String?    // 可选：关联需求
  assigneeId     String?    // 可选：负责人
  createdById    String
  parentId       String?    // 父任务 ID，用于子任务
  startDate      DateTime?
  dueDate        DateTime?
  estimatedHours Float?     // 预估工时（小时）
  sortOrder      Int        @default(0) // 排序权重
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // 关联关系
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirement Requirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy   User         @relation("TaskCreator", fields: [createdById], references: [id])
  // 自关联：父子任务
  parent      Task?        @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Task[]       @relation("TaskHierarchy")
  planItems   PlanItem[]
  timeLogs    TimeLog[]
  comments    Comment[]

  @@index([status])
  @@index([priority])
  @@index([projectId])
  @@index([requirementId])
  @@index([assigneeId])
  @@index([createdById])
  @@index([parentId])
  @@index([type])
  @@map("tasks")
}

/// 缺陷模型 - Bug 跟踪
model Bug {
  id               String      @id @default(cuid())
  title            String
  description      String?     @db.Text
  status           BugStatus   @default(OPEN)
  severity         BugSeverity @default(MAJOR)
  priority         Priority    @default(MEDIUM)
  projectId        String
  assigneeId       String?     // 可选：负责人
  createdById      String
  environment      String?     // 环境信息（如：Chrome 120, Windows 11）
  stepsToReproduce String?     @db.Text // 复现步骤
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // 关联关系
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee  User?    @relation("BugAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy User     @relation("BugCreator", fields: [createdById], references: [id])
  comments  Comment[]

  @@index([status])
  @@index([severity])
  @@index([priority])
  @@index([projectId])
  @@index([assigneeId])
  @@index([createdById])
  @@map("bugs")
}

/// 工时记录模型
model TimeLog {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  hours       Float    // 记录的工时（小时）
  description String?  @db.Text // 工作内容描述
  logDate     DateTime // 工时所属日期
  createdAt   DateTime @default(now())

  // 关联关系
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([logDate])
  @@map("time_logs")
}

/// 通知模型
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  content   String           @db.Text
  linkUrl   String?          // 关联的页面链接
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  // 关联关系
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

/// 评论模型 - 支持对任务、缺陷、需求的评论
model Comment {
  id            String   @id @default(cuid())
  content       String   @db.Text
  authorId      String
  taskId        String?  // 可选：关联任务
  bugId         String?  // 可选：关联缺陷
  requirementId String?  // 可选：关联需求
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 关联关系
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  task        Task?        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  bug         Bug?         @relation(fields: [bugId], references: [id], onDelete: Cascade)
  requirement Requirement? @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([taskId])
  @@index([bugId])
  @@index([requirementId])
  @@index([createdAt])
  @@map("comments")
}

/// 产品线小组模型
model ProductLineTeam {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联项目
  projects    Project[]

  // 关联需求
  requirements Requirement[]
  plans        Plan[]
  planItems    PlanItem[]
  productPlatforms ProductPlatform[]
  productVersions ProductVersion[]

  // 固定成员
  members     ProductLineMember[]

  // 借入/借出的借调记录
  secondmentsFrom MemberSecondment[] @relation("SecondedFrom")
  secondmentsTo   MemberSecondment[] @relation("SecondedTo")

  @@map("product_line_teams")
}

/// 产品/平台模型
model ProductPlatform {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  productLineTeamId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productLineTeam ProductLineTeam @relation(fields: [productLineTeamId], references: [id], onDelete: Cascade)
  modules ProductModule[]

  @@unique([productLineTeamId, name])
  @@index([productLineTeamId])
  @@map("product_platforms")
}

/// 产品板块/模块模型
model ProductModule {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  productPlatformId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productPlatform ProductPlatform @relation(fields: [productPlatformId], references: [id], onDelete: Cascade)
  versions ProductVersion[]

  @@unique([productPlatformId, name])
  @@index([productPlatformId])
  @@map("product_modules")
}

/// 产品版本模型
model ProductVersion {
  id          String   @id @default(cuid())
  title       String
  version     String
  description String?  @db.Text
  status      ProductVersionStatus @default(PLANNING)
  productLineTeamId String
  productModuleId String
  startDate   DateTime?
  releaseDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productLineTeam ProductLineTeam @relation(fields: [productLineTeamId], references: [id], onDelete: Cascade)
  productModule ProductModule @relation(fields: [productModuleId], references: [id], onDelete: Cascade)
  planItems PlanItem[]

  @@unique([productModuleId, version])
  @@index([productLineTeamId])
  @@index([productModuleId])
  @@index([status])
  @@map("product_versions")
}

/// 产品线小组固定成员模型
model ProductLineMember {
  id         String          @id @default(cuid())
  teamId     String
  userId     String
  role       ProductLineRole
  joinedAt   DateTime        @default(now())

  // 关联关系
  team       ProductLineTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId]) // 每个成员在小组里是唯一的
  @@index([teamId])
  @@index([userId])
  @@map("product_line_members")
}

/// 人员临时借调记录模型
model MemberSecondment {
  id          String           @id @default(cuid())
  userId      String           // 借调的人员 ID
  fromTeamId  String?          // 借出的原小组 ID (可选)
  toTeamId    String           // 借入的目标小组 ID
  role        ProductLineRole  // 借调期间在目标小组担任的角色
  startDate   DateTime         // 借调开始时间
  endDate     DateTime?        // 借调结束时间
  status      SecondmentStatus @default(ACTIVE)
  createdAt   DateTime         // 登记时间
  updatedAt   DateTime         @updatedAt

  // 关联关系
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromTeam    ProductLineTeam? @relation("SecondedFrom", fields: [fromTeamId], references: [id], onDelete: SetNull)
  toTeam      ProductLineTeam  @relation("SecondedTo", fields: [toTeamId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fromTeamId])
  @@index([toTeamId])
  @@index([status])
  @@map("member_secondments")
}
